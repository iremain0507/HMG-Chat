{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@wchat/web", "exec", "next", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@wchat/server", "dev"],
      "port": 4000
    }
  ]
}
