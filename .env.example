# 시나리오 A (SSM 터널/실환경) — 실제 값은 .env.local 에 채우고 절대 커밋 금지.
# 비밀정보(시크릿)는 운영에서 AWS Secrets Manager 사용. 본 파일은 키 목록 문서일 뿐.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://USER:PASSWORD@localhost:15432/wchat_dev   # pnpm tunnel → localhost:15432
REDIS_URL=redis://localhost:16379                                 # pnpm tunnel → localhost:16379
JWT_SECRET=__CHANGE_ME_AT_LEAST_32_CHARS__
ALLOWED_DOMAINS=wchat.dev
EMAIL_SENDER_KIND=console
EMAIL_FROM=noreply@wchat.dev
NEXT_PUBLIC_API_BASE=http://localhost:4000/api/v1
# LLM (dev 에서만; 운영은 Secrets Manager)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
