# Phase 0 dev fast-path — `cp .env.local.example .env.local` 후 즉시 동작 (시크릿 stub).
# docker-compose.local.yml 의 postgres/redis 와 일치. 실 LLM 호출은 dev 에서 fail-soft.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://wchat:localdev@localhost:5432/wchat_dev
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-only-32byte-secret-xxxxxxxxxxxx
ALLOWED_DOMAINS=wchat.dev,gmail.com
EMAIL_SENDER_KIND=console
EMAIL_FROM=noreply@wchat.dev
NEXT_PUBLIC_API_BASE=http://localhost:4000/api/v1
