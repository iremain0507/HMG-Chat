#!/usr/bin/env bash
# 커밋 전 항상 실행 (단일 출처 훅 — Husky 미사용, core.hooksPath=.githooks).
#   활성화: bash scripts/setup-hooks.sh  (또는 pnpm install 시 prepare 가 자동 실행)
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# 1) 개발/배포 토폴로지 규칙 (dev = 맥 미니 로컬, deploy = AWS)
"$ROOT/scripts/check-dev-deploy-rules.sh"

# 2) lint-staged (포맷 + ESLint) — 의존성 설치되어 있을 때만
if [ -x "$ROOT/node_modules/.bin/lint-staged" ]; then
  ( cd "$ROOT" && pnpm exec lint-staged --concurrent false )
fi
