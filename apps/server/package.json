{
  "name": "@wchat/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local --env-file=.env.local src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env.local dist/index.js",
    "test": "vitest run --exclude src/__tests__/integration --coverage --coverage.reporter=cobertura --coverage.reporter=text",
    "test:unit": "vitest run --dir src --exclude src/__tests__/integration --coverage --coverage.reporter=cobertura",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "db:reset": "tsx --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local scripts/db-reset.ts && pnpm db:migrate",
    "db:migrate": "tsx --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:status": "tsx --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local scripts/db-migrate-status.ts",
    "db:migrate:expand": "tsx --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local scripts/db-migrate-expand.ts",
    "db:generate": "drizzle-kit generate",
    "openapi:generate": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.36.3",
    "@aws-sdk/client-sesv2": "^3.1085.0",
    "@hono/node-server": "^1.13.0",
    "@wchat/interfaces": "workspace:*",
    "@wchat/shared": "workspace:*",
    "drizzle-orm": "0.36.0",
    "hono": "4.6.0",
    "jsonwebtoken": "^9.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.47.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "2.1.0",
    "drizzle-kit": "0.27.0",
    "tsx": "^4.0.0",
    "vitest": "2.1.0"
  }
}
